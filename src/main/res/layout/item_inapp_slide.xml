<?xml version="1.0" encoding="utf-8"?>
<!--
  Single slide page for the In-App Message ViewPager2.
  Structure:
    - ImageView (top, CENTER_CROP, gone when no image)
    - Content area LinearLayout (background = style.backgroundColor)
      - Title TextView
      - Body TextView
      - Buttons LinearLayout (populated programmatically)
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical">

    <!-- Slide image — fills card width, fixed height, hidden when blank -->
    <ImageView
        android:id="@+id/slideImage"
        android:layout_width="match_parent"
        android:layout_height="220dp"
        android:scaleType="centerCrop"
        android:visibility="gone"
        android:contentDescription="@null" />

    <!-- Content area: background color comes from global style.backgroundColor -->
    <LinearLayout
        android:id="@+id/slideContentArea"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingTop="20dp"
        android:paddingBottom="20dp">

        <TextView
            android:id="@+id/slideTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:textSize="20sp"
            android:textStyle="bold"
            android:lineSpacingExtra="2dp"
            android:visibility="gone" />

        <TextView
            android:id="@+id/slideBody"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:gravity="center"
            android:textSize="15sp"
            android:lineSpacingExtra="2dp"
            android:visibility="gone" />

        <!-- Buttons populated programmatically -->
        <LinearLayout
            android:id="@+id/slideButtonsContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:orientation="vertical" />

    </LinearLayout>

</LinearLayout>


